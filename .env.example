# Copy to .env (gitignored). Used by app.config.ts at build/prebuild time.
# Get a key from Google Cloud Console — restrict it to the Maps SDK for
# Android/iOS and to the com.propfind.mobile application ID.
GOOGLE_MAPS_API_KEY=

# Optional: point the app at a local backend instead of prod. Use your machine's
# LAN IP (not localhost — that resolves to the phone). Unset = prod.
# EXPO_PUBLIC_API_URL=http://192.168.1.5:8080/api
