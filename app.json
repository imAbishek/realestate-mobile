{
  "expo": {
    "name": "PropFind",
    "slug": "realestate-mobile",
    "scheme": "propfind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://realestate-backend-tgbv.onrender.com/api",
      "router": {},
      "eas": {
        "projectId": "f104dd45-9e6c-4867-8063-1f200f0aabee"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.propfind.mobile",
      "config": {}
    },
    "android": {
      "package": "com.propfind.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#173A34",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {}
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "PropFind uses your location to mark the exact spot of the property you're listing on the map. We only use it while the app is open and you tap \"Use my current location\"."
        }
      ],
      "@sentry/react-native",
      "expo-font"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f104dd45-9e6c-4867-8063-1f200f0aabee"
    }
  }
}
